# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

location       = "westeurope"
project_name   = "b4code"
environment    = "production"

# Full image reference — updated automatically by GitHub Actions on each deploy
container_image = "b4codeacrproduction.azurecr.io/prototype:latest"

# Password shown to visitors on the demo login gate
demo_username  = "b4code"
demo_password  = "Demo2026!"

# Scale to zero when idle (Azure Container Apps feature)
min_replicas   = 0
max_replicas   = 2
